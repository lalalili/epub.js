{
  "name": "epubjs",
  "version": "0.3.93",
  "description": "Parse and render EPUB documents in the browser",
  "main": "./dist/epub.cjs",
  "module": "./dist/epub.mjs",
  "browser": "./dist/epub.js",
  "types": "./types/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/index.d.ts",
      "import": "./dist/epub.mjs",
      "require": "./dist/epub.cjs",
      "default": "./dist/epub.mjs"
    },
    "./package.json": "./package.json"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lalalili/epub.js.git"
  },
  "bugs": {
    "url": "https://github.com/lalalili/epub.js/issues"
  },
  "homepage": "https://github.com/lalalili/epub.js#readme",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "npm run test:browser",
    "test:legacy": "node -e \"console.log('No legacy Karma tests remain; use npm run test:browser')\"",
    "test:browser": "vitest run --config vitest.browser.config.mjs",
    "docs": "npm run docs:md",
    "docs:html": "typedoc --options typedoc.html.json",
    "docs:md": "typedoc --options typedoc.json",
    "lint": "node scripts/check-eslint-baseline.mjs",
    "start": "vite --host localhost --port 8080",
    "build": "npm run build:modules && npm run build:umd && npm run build:umd:min && npm run build:clean",
    "build:modules": "vite build --config vite.config.mjs",
    "build:umd": "vite build --config vite.umd.config.mjs",
    "build:umd:min": "MINIFY=true vite build --config vite.umd.config.mjs",
    "build:clean": "node -e \"const fs = require('fs'); for (const p of ['dist/epub.js']) fs.writeFileSync(p, fs.readFileSync(p, 'utf8').replace(/[ \\\\t]+$/gm, ''));\"",
    "build:webpack": "NODE_ENV=production webpack --progress",
    "minify": "npm run build:umd:min",
    "legacy": "NODE_ENV=production LEGACY=true webpack --progress",
    "productionLegacy": "NODE_ENV=production MINIMIZE=true LEGACY=true webpack --progress",
    "verify:contracts": "npm run verify:docs-modernization && npm run verify:package-entry && npm run verify:gate1-readiness && npm run verify:test-modernization && npm run verify:pack-contents && npm run verify:packed-package-entry && npm run verify:release-gate && npm run verify:internal-boundaries && npm run verify:typescript-source-pipeline",
    "verify:docs-modernization": "node scripts/verify-docs-modernization.mjs",
    "verify:gate1-readiness": "node scripts/verify-gate1-readiness.mjs",
    "verify:internal-boundaries": "node scripts/verify-internal-boundaries.mjs",
    "verify:pack-contents": "node scripts/verify-pack-contents.mjs",
    "verify:package-entry": "node scripts/verify-package-entry.mjs",
    "verify:packed-package-entry": "node scripts/verify-packed-package-entry.mjs",
    "verify:release": "npm run lint && npm run typecheck && npm run compile && npm run build && npm run docs:md && npm run verify:contracts && npm run test:browser && npm audit && npm audit --omit=dev && npm pack --dry-run",
    "verify:release-gate": "node scripts/verify-release-gate.mjs",
    "verify:test-modernization": "node scripts/verify-test-modernization.mjs",
    "verify:typescript-source-pipeline": "node scripts/verify-typescript-source-pipeline.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "compile": "babel --extensions \".js,.ts\" -d lib/ src/",
    "watch": "babel --extensions \".js,.ts\" --watch -d lib/ src/",
    "prepare": "npm run compile && npm run build"
  },
  "author": "fchasen@gmail.com",
  "license": "BSD-2-Clause",
  "overrides": {
    "diff": "^8.0.3",
    "serialize-javascript": "^7.0.5",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1"
  },
  "devDependencies": {
    "@babel/cli": "^7.29.7",
    "@babel/core": "^7.29.7",
    "@babel/preset-env": "^7.29.7",
    "@babel/preset-typescript": "^7.29.7",
    "@babel/runtime": "^7.29.7",
    "@vitest/browser-playwright": "^4.1.7",
    "babel-loader": "^9.2.0",
    "eslint": "^8.57.1",
    "playwright": "^1.60.0",
    "terser-webpack-plugin": "^5.6.1",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.15",
    "vitest": "^4.1.7",
    "webpack": "^5.107.2",
    "webpack-cli": "^5.1.0",
    "webpack-dev-server": "^5.2.4"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.13",
    "core-js": "^3.49.0",
    "event-emitter": "^0.3.5",
    "jszip": "^3.10.1",
    "localforage": "^1.10.0",
    "lodash": "^4.17.21",
    "marks-pane": "^1.0.9",
    "path-webpack": "0.0.3",
    "process": "^0.11.10"
  }
}

{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowJs": true,
    "checkJs": false,
    "noEmit": true,
    "noImplicitAny": true,
    "strict": false,
    "lib": [
      "ES2022",
      "DOM",
      "DOM.Iterable"
    ],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "src/**/*.js",
    "src/**/*.ts",
    "types/**/*.d.ts",
    "types/**/*-tests.ts",
    "vite.config.mjs",
    "vite.umd.config.mjs"
  ],
  "exclude": [
    "dist",
    "documentation",
    "lib",
    "node_modules"
  ]
}
